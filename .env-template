# Environment variables for Archivo Vintach (Sharetribe Web Template fork).
#
# IMPORTANT: Variables prefixed with "REACT_APP_" are bundled into the client-side
# JavaScript and exposed to the public web. NEVER put secrets in REACT_APP_ vars.
# https://create-react-app.dev/docs/adding-custom-environment-variables
#
# Copy this file to .env.development for local dev, and set values in
# Heroku/Render config vars for deployed environments.

# ─────────────────────────────────────────────────────────────────────────────
# SHARETRIBE MARKETPLACE API (required)
# ─────────────────────────────────────────────────────────────────────────────
# The Marketplace API handles all user-facing operations: auth, listings, search,
# transactions, etc. It authenticates as a specific user via session tokens.
#
# Get these at: Console → Build → Applications → Add new
#
# CLIENT_ID is public (used in the browser). The CLIENT_SECRET is server-only
# and only needed if your transaction process uses privileged transitions.
# Console also generates a client secret alongside the ID — you can ignore it
# if you don't use privileged transitions.
REACT_APP_SHARETRIBE_SDK_CLIENT_ID=change-me
SHARETRIBE_SDK_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# SHARETRIBE INTEGRATION API (required for AV-noti + bulk import)
# ─────────────────────────────────────────────────────────────────────────────
# The Integration API authenticates as the marketplace operator (not a user).
# It has elevated access: read all events, create listings on behalf of users,
# query across all transactions. Runs server-side only.
#
# Get these at: Console → Build → Integrations → Create integration
#
# Used by:
#   - Event poller / notifications (server/services/eventPoller.js)
#   - Bulk CSV importer (/admin/bulk-import)
#
# If both vars are empty, these features are silently disabled.
SHARETRIBE_INTEGRATION_CLIENT_ID=
SHARETRIBE_INTEGRATION_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# STRIPE (required for payments)
# ─────────────────────────────────────────────────────────────────────────────
# Publishable key only — the secret key is set in Sharetribe Console, not here.
# Use pk_test_ keys for dev/staging, pk_live_ for production.
# Console → Build → Payments → Stripe
REACT_APP_STRIPE_PUBLISHABLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# MAPS
# ─────────────────────────────────────────────────────────────────────────────
REACT_APP_MAPBOX_ACCESS_TOKEN=
# Or use Google Maps instead (uncomment):
# REACT_APP_GOOGLE_MAPS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# MARKETPLACE CONFIG
# ─────────────────────────────────────────────────────────────────────────────
# Host/domain — no trailing slash
REACT_APP_MARKETPLACE_ROOT_URL=http://localhost:3000

# Marketplace name (defaults to 'Biketribe' if not set)
REACT_APP_MARKETPLACE_NAME=ArchivoVintach

# Environment: overridden by .env.development and .env.test locally.
# Set to 'production' in deployed environments.
REACT_APP_ENV=production

# ─────────────────────────────────────────────────────────────────────────────
# SOCIAL LOGINS / SSO (optional)
# ─────────────────────────────────────────────────────────────────────────────
# If the app/client ID is not set, the auth option is hidden in the UI.
REACT_APP_FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

REACT_APP_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# BREVO (newsletter + transactional email)
# ─────────────────────────────────────────────────────────────────────────────
# REACT_APP_ vars are used by the client-side newsletter form.
# Non-prefixed vars are used by the server for transactional emails (welcome email).
REACT_APP_BREVO_API_KEY=
REACT_APP_BREVO_LIST_ID=
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# ─────────────────────────────────────────────────────────────────────────────
# WHATSAPP NOTIFICATIONS (optional, requires AV-noti + Integration API)
# ─────────────────────────────────────────────────────────────────────────────
# Meta Cloud API credentials for sending WhatsApp notifications.
# Get these from Meta Business Manager → WhatsApp → API Setup.
# Templates must be pre-approved in Meta before use.
# If any of these are empty, WhatsApp notifications are silently skipped.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ADMIN_PHONE=

# Optional: override the event poller cursor file path (default: os.tmpdir()).
# On multi-dyno deployments, set this to a shared persistent path or use an
# external cursor store to prevent duplicate notifications on restart.
# AV_EVENT_POLLER_CURSOR_PATH=

 ─────────────────────────────────────────────────────────────────────────────
# INSTAGRAM FEED (optional, requires av-insta-feed block ID + Integration API)
# ─────────────────────────────────────────────────────────────────────────────
# Meta Cloud API credentials for sending WhatsApp notifications.
INSTAGRAM_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# PROVIDER COMMISSION / EARNINGS ESTIMATOR
# ─────────────────────────────────────────────────────────────────────────────
# Percentage and fixed fee come from Console (transactions/commission.json)
# at runtime via mergeConfig. These are fallbacks if the hosted asset is
# unavailable, and are used by the EarningsEstimator display in the listing form.
# REACT_APP_PROVIDER_COMMISSION_PERCENTAGE=10
# REACT_APP_STRIPE_FEE_PERCENTAGE=2.9
# REACT_APP_STRIPE_FEE_FIXED_AMOUNT=30
REACT_APP_PROVIDER_COMMISSION_FIXED_FEE=1500

# ─────────────────────────────────────────────────────────────────────────────
# BULK IMPORT (optional, requires Integration API)
# ─────────────────────────────────────────────────────────────────────────────
# Admin CSV + image importer at /admin/bulk-import.
# API_KEY protects the endpoint — use a strong random value in production.
# DEFAULT_AUTHOR_ID is used for CSV rows that omit author_id.
BULK_IMPORT_API_KEY=
BULK_IMPORT_DEFAULT_AUTHOR_ID=
BULK_IMPORT_LISTING_TYPE=av-listing
BULK_IMPORT_TRANSACTION_ALIAS=default-purchase/release-1
BULK_IMPORT_UNIT_TYPE=item

# ─────────────────────────────────────────────────────────────────────────────
# CSP / SECURITY
# ─────────────────────────────────────────────────────────────────────────────
# Content Security Policy: 'report' (log violations) or 'block' (enforce).
# If missing, CSP is disabled.
REACT_APP_CSP=report

# REACT_APP_SHARETRIBE_USING_SSL=true
# SERVER_SHARETRIBE_TRUST_PROXY=true
# BASIC_AUTH_USERNAME=sharetribe
# BASIC_AUTH_PASSWORD=secret

# ─────────────────────────────────────────────────────────────────────────────
# ANALYTICS (optional)
# ─────────────────────────────────────────────────────────────────────────────
# GA4 ID (starts with 'G-'). Turn off "Enhanced measurements" in GA.
# REACT_APP_GOOGLE_ANALYTICS_ID=change-me

# Plausible: comma-separated domains. Requires a plausible.io account.
# REACT_APP_PLAUSIBLE_DOMAINS=my.marketplace.com

# ─────────────────────────────────────────────────────────────────────────────
# MONITORING (optional)
# ─────────────────────────────────────────────────────────────────────────────
# REACT_APP_SENTRY_DSN=change-me

# ─────────────────────────────────────────────────────────────────────────────
# CACHING / DEBUG (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Cache TTL for proxied SDK asset calls. 0 = no caching.
# TTL=60
# TTL_ASSETS_BY_VERSION=86400

# VERBOSE=true
# PREVENT_DATA_LOADING_IN_SSR=true